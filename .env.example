# ==========================================
# VinClassroom UI - Environment Configuration
# ==========================================
# Copy this file to .env and update the values

# API Configuration
# Base URL for the NestJS backend API
VITE_API_URL=http://localhost:3000/api

# Agent API Configuration
# Base URL for the StudyBot Agent API
VITE_AGENT_API_URL=http://localhost:8000

# WebSocket Configuration
# URL for the Socket.IO server (usually the same as backend URL without /api)
VITE_SOCKET_URL=http://localhost:3000

# Application Configuration
# Application name (optional)
VITE_APP_NAME=VinClassroom

# Enable debug mode (optional, default: false)
VITE_DEBUG=false

# ==========================================
# Production Example
# ==========================================
# VITE_API_URL=https://api.yourdomain.com/api
# VITE_SOCKET_URL=https://api.yourdomain.com
